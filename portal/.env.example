DATABASE_URL=postgres://user:pass@localhost:5432/riding_lookup_portal
AUTH_SECRET=replace-with-long-random-string
BETTER_AUTH_URL=http://localhost:5173
BASE_URL=http://localhost:5173

WORKER_PROJECTION_URL=http://localhost:8787
WORKER_PROJECTION_SECRET=shared-with-worker-PROJECTION_ADMIN_SECRET
# Public Worker URL for marketing try-it + docs links (defaults to WORKER_PROJECTION_URL).
PUBLIC_API_BASE_URL=http://localhost:8787
# Optional: pk_* for /api/search on the marketing try-it embed (allowlist the portal origin).
# Riding resolution uses keyless /api/demo/*; leave empty when API_KEYS is unbound.
DEMO_BROWSER_API_KEY=

STRIPE_SECRET_KEY=sk_test_…
STRIPE_WEBHOOK_SECRET=whsec_…
STRIPE_PRICE_METERED=price_…
# Keep false until product addendum + licence checklist are done.
PAID_CHECKOUT_ENABLED=false

RESEND_API_KEY=
EMAIL_FROM=CanCoder <noreply@example.com>

# Founder user ids (comma-separated) allowed to flip batchEnabled
FOUNDER_USER_IDS=
