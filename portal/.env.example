# Local dev config for the combined portal + API Worker. Copy this to `.dev.vars` (the file
# `wrangler dev` / `npm run dev` actually reads via the Cloudflare Vite plugin) and fill in real
# values. In production/staging these are set with `wrangler secret put NAME` — see wrangler.jsonc.
#
# There is no DATABASE_URL anymore: the portal's D1 database (PORTAL_DB) is a wrangler.jsonc
# binding, not a connection string — see README.md "Local setup".

# --- API worker (src/worker.ts) ---
GEOCODER=nominatim
BASIC_AUTH=dev:dev
PROJECTION_ADMIN_SECRET=local-dev-shared-secret

# --- Portal (React Router) ---
AUTH_SECRET=replace-with-long-random-string
BASE_URL=http://localhost:5173
PUBLIC_API_BASE_URL=http://localhost:5173
# Optional: pk_* for /api/search on the marketing try-it embed (allowlist the portal origin).
# Riding resolution uses keyless /api/demo/*; leave empty when API_KEYS is unbound.
DEMO_BROWSER_API_KEY=

STRIPE_SECRET_KEY=sk_test_…
STRIPE_WEBHOOK_SECRET=whsec_…
STRIPE_PRICE_METERED=price_…
# Keep false until product addendum + licence checklist are done.
PAID_CHECKOUT_ENABLED=false

RESEND_API_KEY=
EMAIL_FROM=CanCoder <noreply@example.com>

# Founder user ids (comma-separated) allowed to flip batchEnabled
FOUNDER_USER_IDS=
