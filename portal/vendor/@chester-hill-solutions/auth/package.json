    },
    "./token": {
      "types": "./dist/token.d.ts",
      "import": "./dist/token.js",
      "default": "./dist/token.js"
    }
  },
  "peerDependencies": {
    "cookie": "^1.0.0",
    "postgres": "^3.4.0"
  },
  "peerDependenciesMeta": {
    "cookie": {
      "optional": false
    },
    "postgres": {
      "optional": true
    }
  }
}
