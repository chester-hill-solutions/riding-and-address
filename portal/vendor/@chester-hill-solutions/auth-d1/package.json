{
  "name": "@chester-hill-solutions/auth-d1",
  "version": "0.1.0",
  "description": "Cloudflare D1 (SQLite) auth provider — auth() factory, session reader, workspace invitations, feature permissions (Better Auth)",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chester-hill-solutions/chester-hill-solutions.git",
    "directory": "packages/auth-d1"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.types-test.json",
    "test": "bun test src/",
    "prepublishOnly": "npm run build"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./schema": {
      "types": "./dist/schema.d.ts",
      "import": "./dist/schema.js",
      "default": "./dist/schema.js"
    },
    "./plugins": {
      "types": "./dist/plugins.d.ts",
      "import": "./dist/plugins.js",
      "default": "./dist/plugins.js"
    },
    "./drizzle-adapter": {
      "types": "./dist/drizzle-adapter.d.ts",
      "import": "./dist/drizzle-adapter.js",
      "default": "./dist/drizzle-adapter.js"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "import": "./dist/testing/index.js",
      "default": "./dist/testing/index.js"
    }
  },
  "dependencies": {
    "@chester-hill-solutions/auth": "file:../auth"
  },
  "peerDependencies": {
    "@better-auth/drizzle-adapter": "^1.6.0",
    "better-auth": "^1.6.0",
    "drizzle-orm": "^0.45.0"
  },
  "devDependencies": {
    "@better-auth/drizzle-adapter": "^1.6.11",
    "better-auth": "^1.6.11",
    "bun-types": "^1.3.5",
    "drizzle-orm": "^0.45.2",
    "typescript": "^5.9.2"
  }
}
