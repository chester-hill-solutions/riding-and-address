{
  "name": "ridinglookup",
  "version": "1.0.0",
  "description": "CanCoder: Canadian address geocoding, autocomplete, and electoral district API on Cloudflare Workers.",
  "main": "index.js",
  "dependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260716.1",
    "@eslint/js": "^10.0.1",
    "@scalar/api-reference": "^1.62.8",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^26.1.1",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10",
    "wrangler": "^4.111.0"
  },
  "scripts": {
    "dev": "npm --prefix portal run dev",
    "deploy": "npm --prefix portal run deploy",
    "deploy:staging": "npm --prefix portal run deploy:staging",
    "build": "tsc --noEmit && tsc --noEmit -p tsconfig.dom.json",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.dom.json",
    "lint": "eslint src/**/*.ts test/**/*.ts scripts/**/*.ts --max-warnings 0",
    "lint:fix": "eslint src/**/*.ts test/**/*.ts scripts/**/*.ts --fix --max-warnings 0",
    "validate": "npm run lint && npm run typecheck && npm run check:billing-invariants && npm test",
    "check:billing-invariants": "node scripts/check-billing-invariants.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:oda": "vitest run test/oda-normalize.test.ts test/oda-geocoding.test.ts test/oda-fixture-cases.test.ts test/oda-config.test.ts test/canada-post-format.test.ts",
    "test:oda:live": "ODA_LIVE=1 vitest run test/oda-geocoding-live.test.ts",
    "benchmark:lookup": "tsx scripts/benchmark-lookup.ts",
    "compare:opennorth": "tsx scripts/compare-opennorth.ts",
    "compare:report": "tsx scripts/generate-comparison-report.ts",
    "upload:r2-datasets": "tsx scripts/upload-r2-datasets.ts",
    "acquire:provincial-ridings": "python3 scripts/acquire-provincial-ridings.py",
    "import:oda:all": "tsx scripts/import-oda.ts --download --provinces ALL --remote --skip-schema --resume",
    "import:oda:centroids": "bash scripts/rebuild-oda-centroids.sh",
    "import:oda": "tsx scripts/import-oda.ts",
    "build:oda:suggest": "tsx scripts/build-oda-suggest.ts",
    "keys": "tsx scripts/manage-keys.ts",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "",
  "license": "ISC"
}
